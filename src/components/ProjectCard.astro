---
interface Props {
  slug: string;
  title: string;
  description: string;
  techStack: string[];
  image: string;
}

const { slug, title, description, techStack, image } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<article class="project-card panel">
  <a class="project-link" href={`${basePath}projects/${slug}/`}>
    <div class="cover-wrap">
      <img src={`${basePath}${image.replace(/^\//, "")}`} alt={`${title} 封面图`} loading="lazy" />
    </div>
    <div class="card-copy">
      <h3>{title}</h3>
      <p>{description}</p>
      <ul class="tag-list">
        {techStack.map((item) => <li>{item}</li>)}
      </ul>
      <span class="detail-link">查看详情</span>
    </div>
  </a>
</article>

<style>
  .project-card {
    overflow: hidden;
    transition: transform 0.22s ease, border-color 0.22s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(102, 179, 255, 0.32);
  }

  .project-link {
    display: grid;
    color: inherit;
  }

  .cover-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: #081321;
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-copy {
    display: grid;
    gap: 0.9rem;
    padding: 1.2rem;
  }

  .card-copy h3 {
    margin: 0;
    font-size: 1.32rem;
    color: var(--text);
  }

  .card-copy p {
    margin: 0;
    color: var(--muted);
  }

  .detail-link {
    color: var(--accent-strong);
    font-weight: 700;
  }
</style>
