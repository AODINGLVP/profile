---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../consts";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../data/projects.json";
---

<BaseLayout>
  <section class="hero panel">
    <div>
      <p class="eyebrow">作品集</p>
      <h1>{siteConfig.name}</h1>
      <p class="bio">{siteConfig.bio}</p>
      <div class="hero-links">
        <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer">GitHub</a>
        <a href={siteConfig.bilibiliUrl} target="_blank" rel="noreferrer">Bilibili</a>
      </div>
    </div>
    <div class="hero-note">
      <p class="eyebrow">项目展示</p>
      <p class="section-copy">这里直接展示全部项目。每个卡片都有封面图，点击后会进入独立详情页查看完整介绍、技术细节和视频链接。</p>
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <p class="eyebrow">全部项目</p>
      <h2 class="section-title">面向中文访问者的项目展示首页。</h2>
      <p class="section-copy">项目数据集中维护在 `src/data/projects.json`，封面图放在 `public/projects`，后续继续扩展也很方便。</p>
    </div>

    <div class="project-grid">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 1.5rem;
    padding: clamp(1.4rem, 4vw, 2.6rem);
    align-items: end;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    line-height: 0.95;
  }

  .bio {
    margin: 1rem 0 0;
    max-width: 34rem;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(102, 179, 255, 0.24);
    background: linear-gradient(180deg, rgba(102, 179, 255, 0.18), rgba(102, 179, 255, 0.08));
    color: var(--text);
    font-weight: 700;
  }

  .hero-note {
    padding: 1.2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(8, 18, 33, 0.8), rgba(19, 40, 67, 0.65));
  }

  .home-section {
    margin-top: 2rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 900px) {
    .hero,
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
