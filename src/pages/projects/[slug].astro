---
import BaseLayout from "../../layouts/BaseLayout.astro";
import projects from "../../data/projects.json";
import { getBilibiliEmbedUrl } from "../../utils/bilibili";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const imageSrc = `${basePath}${project.image.replace(/^\//, "")}`;
const bilibiliEmbedUrl = getBilibiliEmbedUrl(project.bilibiliLink);
---

<BaseLayout title={`${project.title} | 项目详情`} description={project.description}>
  <article class="project-detail">
    <a class="back-link" href={`${basePath}`}>返回首页</a>

    <section class="project-hero panel">
      <div class="hero-copy">
        <p class="eyebrow">项目详情</p>
        <h1>{project.title}</h1>
        <p class="lead">{project.description}</p>
        <ul class="tag-list">
          {project.techStack.map((item) => <li>{item}</li>)}
        </ul>
        <div class="action-row">
          <a href={project.githubLink} target="_blank" rel="noreferrer">GitHub 仓库</a>
          {project.bilibiliLink && <a href={project.bilibiliLink} target="_blank" rel="noreferrer">Bilibili 视频</a>}
        </div>
      </div>

      <div class="hero-image">
        <img src={imageSrc} alt={`${project.title} 封面图`} />
      </div>
    </section>

    <section class="detail-grid">
      <section class="content panel">
        <h2>项目介绍</h2>
        {project.content.map((paragraph) => <p>{paragraph}</p>)}
      </section>

      <aside class="media panel">
        <h2>视频演示</h2>
        {bilibiliEmbedUrl ? (
          <div class="video-frame">
            <iframe
              src={bilibiliEmbedUrl}
              title={`${project.title} Bilibili 视频`}
              loading="lazy"
              allowfullscreen
            />
          </div>
        ) : (
          <p class="muted">当前还没有可播放的 Bilibili 链接。只要在项目数据里填入普通视频链接，这里就会自动显示播放器。</p>
        )}

        <div class="side-links">
          <a href={project.githubLink} target="_blank" rel="noreferrer">查看代码</a>
          {project.bilibiliLink ? (
            <a href={project.bilibiliLink} target="_blank" rel="noreferrer">打开原视频</a>
          ) : (
            <span class="disabled-link">暂未填写视频链接</span>
          )}
        </div>
      </aside>
    </section>
  </article>
</BaseLayout>

<style>
  .project-detail {
    display: grid;
    gap: 1.5rem;
  }

  .back-link {
    color: var(--accent-strong);
    font-weight: 700;
  }

  .project-hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 1.4rem;
    padding: 1.4rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.04;
  }

  .lead {
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 1.04rem;
  }

  .hero-image img {
    width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  .action-row,
  .side-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.2rem;
  }

  .action-row a,
  .side-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.78rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(102, 179, 255, 0.24);
    background: rgba(102, 179, 255, 0.08);
    color: var(--text);
    font-weight: 700;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.25rem;
  }

  .content,
  .media {
    padding: 1.35rem;
  }

  .content h2,
  .media h2 {
    margin-top: 0;
  }

  .content p,
  .muted {
    color: var(--muted);
  }

  .video-frame {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: #030a13;
  }

  .video-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .disabled-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .project-hero,
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
